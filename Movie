CREATE DATABASE MOVIES;
USE MOVIES;

CREATE TABLE Movie
(
	title Char(128),
    year INT,
    length INT,
    genre Char(64)
);

ALTER TABLE Movie ADD movieid Char(64) PRIMARY KEY; 

