CREATE TABLE Moviestar
(
	strid Char(128) Primary Key,
    name Char(128),
    address TEXT(255),
    gender Char(8),
    movieid Char(64),
    
    FOREIGN KEY (movieid) REFERENCES Movie (movieid)
);

